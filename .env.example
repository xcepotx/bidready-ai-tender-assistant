# BidReady AI Tender Assistant
# Copy this file to .env and adjust values for your environment.

# API
INTERNAL_API_KEY=change-me-internal-api-key
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=local

# Database
DATABASE_URL=sqlite:////app/data/bidready.db

# Storage / generated files
UPLOAD_DIR=/app/uploads
EXPORT_DIR=/app/exports

# Web
VITE_API_BASE_URL=http://127.0.0.1

# Optional AI provider settings
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# AI_PROVIDER=rules_only
