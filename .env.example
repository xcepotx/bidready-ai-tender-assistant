# BidReady AI Tender Assistant
# Copy this file to .env and adjust values for your environment.

# API
INTERNAL_API_KEY=change-me-internal-api-key
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=local

# Database
DATABASE_URL=sqlite:////app/data/bidready.db

# Storage / generated files
UPLOAD_DIR=/app/uploads
EXPORT_DIR=/app/exports

# Web
VITE_API_BASE_URL=http://127.0.0.1

# Optional AI provider settings
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# AI_PROVIDER=rules_only

# Database schema management
# Development default can stay true for convenience.
# Production should run Alembic migrations and set this to false.
BIDREADY_AUTO_CREATE_TABLES=true

# PostgreSQL connection used by docker compose and API
POSTGRES_DB=tender_ai
POSTGRES_USER=tender_user
POSTGRES_PASSWORD=tender_dev_password_change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
